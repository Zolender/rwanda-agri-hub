

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}



enum MovementType {
  Sale
  Adjustment
  Purchase
}

model Product {
  id                   String        @id // product_id (SKU)
  categoryId           String        
  unitOfMeasure        String
  unitCostRwf          Float
  sellingPriceRwf      Float
  landedCostRwf        Float
  reorderPointUnits    Int
  leadTimeBufferDays   Int
  transactions         Transaction[]
}

model Transaction {
  id                    String       @id @default(cuid())
  orderId               String       
  productId             String
  product               Product      @relation(fields: [productId], references: [id])
  movementType          MovementType
  quantityOrderedUnits  Int?
  quantityFulfilledUnits Int
  remainingStockUnits   Int          
  customerId            String?
  supplierId            String?
  poId                  String?
  region                String
  lostSaleQtyUnits      Int          @default(0)
  transactionDate       DateTime     
  createdAt             DateTime     @default(now())
}