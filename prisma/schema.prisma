

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}



enum MovementType {
  Sale
  Adjustment
  Purchase
}

model Product {
  id                   String        @id // product_id (SKU)
  categoryId           String        
  unitOfMeasure        String
  unitCostRwf          Float
  sellingPriceRwf      Float
  landedCostRwf        Float
  reorderPointUnits    Int
  leadTimeBufferDays   Int
  quantity             Int       @default(0)
  transactions         Transaction[]
}

model Transaction {
  id                    String       @id @default(cuid())
  orderId               String       
  productId             String
  product               Product      @relation(fields: [productId], references: [id])
  movementType          MovementType
  quantityOrderedUnits  Int?
  remainingStockUnits   Int          
  customerId            String?
  supplierId            String?
  poId                  String?
  region                String
  lostSaleQtyUnits      Int          @default(0)
  transactionDate       DateTime     
  createdAt             DateTime     @default(now())

  shipment              Shipment?
  fxRate                FXRate?
  metrics               TransactionMetrics?
}



model Shipment{
  id                    String       @id @default(cuid())
  transactionId         String       @unique
  transaction           Transaction  @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  shipType              String?
  country               String?
  portName              String?
  cargoDescription      String?
  arrivalTime           DateTime?
  departureTime         DateTime?
  portDelays            Int?
  lastPort              String?
  nextPort              String?
  currentStatus         String?

  createdAt             DateTime    @default(now())
}


model FXRate{
  id                    String       @id @default(cuid())
  transactionId         String       @unique
  transaction           Transaction  @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  usdToRwf              Float?
  eurToRwf              Float?
  timestamp             DateTime?
  fxVolatility          Float?
  createdAt             DateTime    @default(now())

}


model TransactionMetrics{
  id                    String       @id @default(cuid())
  transactionId         String       @unique
  transaction           Transaction  @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  fulfillmentRatio      Float?
  stockPressure         Float?
  createdAt             DateTime     @default(now())
}





// --- AUTH TABLES ---

enum UserRole {
  ADMIN
  MANAGER
  ANALYST
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // We add this for Email/Password login
  role          UserRole  @default(ANALYST) // Default role for new users
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}