generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id                 String        @id
  categoryId         String
  unitOfMeasure      String
  unitCostRwf        Float
  sellingPriceRwf    Float
  landedCostRwf      Float
  reorderPointUnits  Int
  leadTimeBufferDays Int
  quantity           Int           @default(0)
  transactions       Transaction[]

  @@index([categoryId])
}

model Transaction {
  id                   String              @id @default(cuid())
  orderId              String
  productId            String
  movementType         MovementType
  quantityOrderedUnits Int
  remainingStockUnits  Int
  customerId           String?
  supplierId           String?
  poId                 String?
  region               String
  lostSaleQtyUnits     Int                 @default(0)
  transactionDate      DateTime
  createdAt            DateTime            @default(now())
  fxRate               FXRate?
  shipment             Shipment?
  product              Product             @relation(fields: [productId], references: [id])
  metrics              TransactionMetrics?

  @@index([productId])
  @@index([movementType])
  @@index([transactionDate])
  @@index([region])
  @@index([productId, transactionDate])
}

model Shipment {
  id               String      @id @default(cuid())
  transactionId    String      @unique
  shipType         String?
  country          String?
  portName         String?
  cargoDescription String?
  arrivalTime      DateTime?
  departureTime    DateTime?
  portDelays       Int?
  lastPort         String?
  nextPort         String?
  currentStatus    String?
  createdAt        DateTime    @default(now())
  transaction      Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

model FXRate {
  id            String      @id @default(cuid())
  transactionId String      @unique
  usdToRwf      Float?
  eurToRwf      Float?
  timestamp     DateTime?
  fxVolatility  Float?
  createdAt     DateTime    @default(now())
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

model TransactionMetrics {
  id               String      @id @default(cuid())
  transactionId    String      @unique
  stockPressure    Float?
  createdAt        DateTime    @default(now())
  fulfillmentRatio Float?
  transaction      Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole   @default(ANALYST)
  accounts      Account[]
  sessions      Session[]
  auditLogs     AuditLog[] // a user can have many audit log entries
  createdAt     DateTime   @default(now())
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Audit Log ──────────────────────────────────────────────────────────────────
// Records every important mutation in the system.
// userId is optional (?) so we can still log if session lookup fails gracefully.
model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  userEmail  String?     // denormalised — so we still see who did it even if user is deleted
  userRole   String?
  action     AuditAction
  targetId   String?     // the ID of the thing being acted on (productId, userId, etc.)
  targetType String?     // "Product", "User", "Transaction" — what kind of thing
  detail     String?     // human-readable description: "Changed price 500 → 650"
  createdAt  DateTime    @default(now())
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  // We'll query by userId and by action type most often
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

enum MovementType {
  Sale
  Adjustment
  Purchase
}

enum UserRole {
  ADMIN
  MANAGER
  ANALYST
}

enum AuditAction {
  CREATE_USER
  UPDATE_ROLE
  DELETE_USER
  UPDATE_PRODUCT
  RECORD_SALE
  RECORD_PURCHASE
  CHANGE_PASSWORD
}